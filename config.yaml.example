minimap:
  region:
    top: 850
    left: 20
    width: 200
    height: 200

detection:
  enemy_color_lower: [0, 120, 70]
  enemy_color_upper: [10, 255, 255]
  enemy_color_lower2: [170, 120, 70]
  enemy_color_upper2: [180, 255, 255]
  team_color_lower: [80, 100, 100]
  team_color_upper: [100, 255, 255]
  min_contour_area: 5
  ability_min_area: 4
  # Per-ability HSV overrides (optional, tune to your monitor):
  # abilities:
  #   reyna_eye:
  #     lower: [145, 80, 140]
  #     upper: [165, 255, 255]
  #   viper_wall:
  #     lower: [55, 140, 110]
  #     upper: [85, 255, 255]

app_version: "1.0"   # increment after each release for dataset slicing

ai:
  enabled: true
  model: "claude-sonnet-4-6"
  analyze_interval: 3.0
  # --- local model (after running scripts/train.py) ---
  use_local_model: false
  local_model_path: "models/minimap_coach_lora/best"

audio:
  engine: "pyttsx3"
  rate: 160
  cooldown: 2.0

# Leave map_override as null for automatic map detection.
# Set to a map name (e.g. "ascent") only if auto-detect misbehaves.
map_override: null

map_detection:
  model: "claude-haiku-4-5-20251001"  # cheapest model, task is trivial classification
  recheck_interval: 300      # seconds between re-checks during a session
  startup_retry_interval: 10 # seconds between retries when not in-game yet

overlay:
  fade_after: 5.0  # seconds for enemy dot to fade after last detection

data_collection:
  enabled: true           # opt-in: set true to contribute training data
  hf_repo: "naithai/valorant-minimap-coach"              # e.g. "your-name/valorant-coach-data" (HuggingFace dataset repo)
  hf_token: ""             # HuggingFace token with write access (Settings → Access Tokens)

audio_coach:
  enabled: true
  # Loopback/monitor device name (partial match). Leave null for auto-detect.
  # Windows:  null  (auto WASAPI loopback)
  # macOS:    "BlackHole" or "Loopback"
  # Linux:    "monitor" (PulseAudio)
  device: null
  # Minimum classifier confidence (0-1) to name an agent in callouts.
  # Below this threshold, callouts say "someone" instead of agent name.
  agent_conf_threshold: 0.45
